# Production Environment Configuration
# Copy this file to .env.production and fill in your values

# Database - Use a managed PostgreSQL service (Railway, Render, AWS RDS)
DATABASE_URL=postgresql://user:password@host:5432/wineapi

# Redis - Use a managed Redis service
REDIS_URL=redis://host:6379/0

# Security - Generate a strong random string
SECRET_KEY=your-super-secret-key-here-change-me

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Restrict to your production domain
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Email (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# API Configuration
API_KEY=your-default-api-key-change-me
